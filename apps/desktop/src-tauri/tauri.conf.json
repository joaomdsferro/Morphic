{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Morphic",
  "version": "0.0.1",
  "identifier": "com.morphic.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @morphic/web dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter @morphic/web build",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Morphic",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
